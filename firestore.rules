rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LOCAL HELPLINK SECURITY RULES
     * Secure access for a hyperlocal help network.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User Profiles: Anyone signed in can view profiles; only owners can edit
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Help Requests: Authenticated users can browse (get/list) and create.
    // Explicitly defining list, get ensures no ambiguity for collection queries.
    match /requests/{requestId} {
      allow list, get, create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid || 
        isAdmin()
      );
    }

    // Notifications: Strictly private to the recipient
    match /notifications/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // Ratings: Anyone signed in can view or leave a rating
    match /ratings/{ratingId} {
      allow read, create: if isSignedIn();
      allow update, delete: if false; // Ratings are immutable
    }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}