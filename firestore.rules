rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LOCAL HELPLINK SECURITY RULES
     * Secure access for a hyperlocal help network.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User Profiles
    match /users/{userId} {
      // Authenticated users can read profiles and list the directory
      allow read: if isSignedIn();
      // Users can only manage their own profile data
      allow write: if isOwner(userId);
    }

    // Help Requests
    match /requests/{requestId} {
      // Authenticated users can browse the community feed (get and list)
      allow read: if isSignedIn();
      // Authenticated users can create a new request
      allow create: if isSignedIn();
      
      // Only the creator or an admin can modify/delete
      allow update, delete: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid || 
        isAdmin()
      );
    }

    // Notifications - strictly private to the recipient
    match /notifications/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // Ratings
    match /ratings/{ratingId} {
      // Anyone signed in can see ratings or leave one
      allow read, create: if isSignedIn();
      // Ratings are immutable
      allow update, delete: if false;
    }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
