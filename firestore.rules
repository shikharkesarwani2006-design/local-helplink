rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LOCAL HELPLINK SECURITY RULES (PROTOTYPING MODE)
     *
     * Core Philosophy:
     * This ruleset implements a robust authorization model for a community-driven help platform. 
     * It prioritizes verified identity and resource ownership while allowing for the flexible 
     * data evolution required during the prototyping phase.
     *
     * Data Structure:
     * - /users/{userId}: Private and public profile information.
     * - /requests/{requestId}: A global feed of help requests.
     * - /ratings/{ratingId}: Feedback given after completed help sessions.
     * - /admin_roles/{adminUid}: A secure flag collection for administrative privileges.
     *
     * Key Security Decisions:
     * - Ownership-Based Writes: Most resources (profiles, requests) can only be modified by the creator.
     * - Collaborative Transition: Help requests allow a specific state transition (Open -> Accepted) 
     *   by users who are not the owner, facilitating the "volunteer" mechanic.
     * - Admin Override: Users listed in the `admin_roles` collection have global read/write access.
     * - Denormalization for Authorization: The `createdBy` and `acceptedBy` fields are strictly 
     *   required on request documents to allow for fast, non-hierarchical authorization.
     * - Public Reading: Signed-in users can view all requests and user profiles to facilitate 
     *   discovery and the leaderboard features.
     */

    // --- Helper Functions ---

    /** Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * Checks for administrative privileges using the dedicated admin_roles collection.
     * This avoids calling get() on the primary users collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    /** Verifies a document exists and the current user is the owner. */
    function isExistingOwner(ownerId) {
      return resource != null && isOwner(ownerId);
    }

    /** Validates that a field has not been modified during an update. */
    function isUnchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents. Allows self-creation and updates.
     * @path /users/{userId}
     * @allow get (signed-in user), list (signed-in user), create/update (owner)
     * @deny write (mismatched UID), delete (non-admin)
     * @principle Ownership and Self-Creation (P3.1, P3.4).
     */
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) || isAdmin()) && isUnchanged('id');
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for help requests. Supports the "Accept & Help" transition.
     * @path /requests/{requestId}
     * @allow create (owner), update (owner or volunteer accepting open request)
     * @deny create (spoofing creatorId), update (stealing an accepted request)
     * @principle Ownership (P3.1) and Managed State Transition.
     */
    match /requests/{requestId} {
      allow get, list: if isSignedIn();
      
      allow create: if isSignedIn() 
        && request.resource.data.createdBy == request.auth.uid 
        && request.resource.data.status == 'open';

      allow update: if isSignedIn() && (
        // Case 1: Owner editing their own request (cannot change creator)
        (isExistingOwner(resource.data.createdBy) && isUnchanged('createdBy')) ||
        // Case 2: Volunteer accepting an "open" request
        (
          resource.data.status == 'open' && 
          request.resource.data.status == 'accepted' && 
          request.resource.data.acceptedBy == request.auth.uid &&
          isUnchanged('createdBy')
        ) ||
        isAdmin()
      );

      allow delete: if isExistingOwner(resource.data.createdBy) || isAdmin();
    }

    /**
     * @description Rules for ratings between users. Immutable once created.
     * @path /ratings/{ratingId}
     * @allow create (fromUser matches auth), get/list (signed-in)
     * @deny update (all), delete (non-admin)
     * @principle Verified Identity (P2) and Immutability.
     */
    match /ratings/{ratingId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.fromUser == request.auth.uid;
      allow update: if false; // Ratings should not be changed once submitted
      allow delete: if isAdmin();
    }

    /**
     * @description Secure flag collection for managing administrative roles.
     * @path /admin_roles/{adminUid}
     * @allow read/write (admin only)
     * @principle Structural Segregation for Authorization.
     */
    match /admin_roles/{adminUid} {
      // Only existing admins can manage the admin list. 
      // Initial admin setup usually occurs via Firebase Console.
      allow read, write: if isAdmin();
    }
  }
}