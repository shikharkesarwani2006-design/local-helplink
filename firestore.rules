rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LOCAL HELPLINK SECURITY RULES
     * 
     * Core Principles:
     * 1. Authentication is required for all read/write operations.
     * 2. Help requests can be viewed by any authenticated user (listing support).
     * 3. Only the creator of a request can modify or delete it.
     * 4. Users can only modify their own profile documents.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User Profiles
    match /users/{userId} {
      // Any authenticated user can view profiles
      allow get, list: if isSignedIn();
      
      // Users can only create or update their own profile
      allow create, update: if isOwner(userId);
      
      // Deletion is restricted
      allow delete: if false;
    }

    // Help Requests
    match /requests/{requestId} {
      // All authenticated users can read and list help requests
      allow get, list: if isSignedIn();
      
      // Any authenticated user can create a help request
      allow create: if isSignedIn() 
        && request.resource.data.createdBy == request.auth.uid;
      
      // Only the creator can update or delete the request
      allow update, delete: if isSignedIn() 
        && resource.data.createdBy == request.auth.uid;
    }

    // Notifications (Strict Owner Only)
    match /notifications/{userId}/items/{notificationId} {
      allow read, write: if isOwner(userId);
    }

    // Ratings
    match /ratings/{ratingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.fromUser == request.auth.uid;
      allow update, delete: if false;
    }

    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}