rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LOCAL HELPLINK SECURITY RULES
     * Explicitly granting list permissions to resolve dashboard access issues.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // User Profiles
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    // Help Requests
    match /requests/{requestId} {
      // Allow all signed-in users to list the collection and read individual documents
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      
      // Allow creation if the user is signed in
      allow create: if isSignedIn();
      
      // Only the creator can modify or delete their own request
      allow update, delete: if isSignedIn() 
        && resource.data.createdBy == request.auth.uid;
    }

    // Notifications
    match /notifications/{userId}/items/{notificationId} {
      allow get, list, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Ratings
    match /ratings/{ratingId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}