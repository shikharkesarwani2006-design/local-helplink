rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LOCAL HELPLINK SECURITY RULES
     * Updated to ensure 'list' operations are explicitly permitted for authenticated users.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin';
    }

    // User Profiles: Anyone signed in can view profiles; only owners or admins can edit
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Help Requests: Authenticated users can browse (get/list) and create missions.
    match /requests/{requestId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid || isAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid || isAdmin()
      );
    }

    // Notifications: Strictly private to the recipient
    match /notifications/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // Ratings: Anyone signed in can view or leave a rating
    match /ratings/{ratingId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false; // Ratings remain immutable for integrity
    }

    // Catch-all deny to ensure no unauthorized access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}