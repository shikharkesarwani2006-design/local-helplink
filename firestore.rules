rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LOCAL HELPLINK SECURITY RULES
     * Secure access for a hyperlocal help network.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // User Profiles
    match /users/{userId} {
      // Anyone signed in can view basic profiles for trust
      allow get, list: if isSignedIn();
      // Only the user themselves can edit their profile
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    // Help Requests
    match /requests/{requestId} {
      // All authenticated users can browse and search the mission feed
      allow get, list: if isSignedIn();
      
      // Any authenticated user can create a request
      allow create: if isSignedIn();
      
      // Only the creator can modify or delete their own request
      allow update, delete: if isSignedIn() 
        && resource.data.createdBy == request.auth.uid;
    }

    // Notifications
    match /notifications/{userId}/items/{notificationId} {
      // Users can only access their own notification stream
      allow get, list, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Ratings
    match /ratings/{ratingId} {
      // Ratings are public for transparency within the community
      allow get, list: if isSignedIn();
      // Any signed in user can submit a rating
      allow create: if isSignedIn();
      // Ratings cannot be modified or deleted to prevent manipulation
      allow update, delete: if false;
    }

    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
