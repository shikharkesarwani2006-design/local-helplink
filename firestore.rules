rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LOCAL HELPLINK SECURITY RULES
     * Secure access for a hyperlocal help network.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      // Only the user themselves can edit their profile
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    // Help Requests
    match /requests/{requestId} {
      // Allow individual get and collection list for the mission feed
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      
      // Only the creator or an admin can modify/delete
      allow update, delete: if isSignedIn() 
        && (resource.data.createdBy == request.auth.uid || 
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Notifications
    match /notifications/{userId}/{document=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Ratings
    match /ratings/{ratingId} {
      allow read, create: if isSignedIn();
      allow update, delete: if false;
    }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
