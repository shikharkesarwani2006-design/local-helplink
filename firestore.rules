rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LOCAL HELPLINK SECURITY RULES
     * Ensures robust 'read' and 'list' access for authenticated users.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check for admin role safely without causing evaluation loops
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User Profiles: Authenticated users can view profiles; only owners or admins can edit
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Help Requests: Authenticated users can browse (get/list) and create missions.
    match /requests/{requestId} {
      // Explicitly allow list and get for the community feed
      allow read, list, get: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid || isAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid || isAdmin()
      );
    }

    // Notifications: Strictly private to the recipient
    match /notifications/{userId}/{document=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Ratings: Anyone signed in can view or leave a rating
    match /ratings/{ratingId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
    }

    // Catch-all deny to ensure no unauthorized access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}