rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LOCAL HELPLINK SECURITY RULES (Simplified for Stability)
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
    }

    // Help Requests
    match /requests/{requestId} {
      // Allow any signed-in user to read (get/list)
      allow read: if isSignedIn();
      
      // Allow creation if the user claims to be the creator
      allow create: if isSignedIn() 
        && request.resource.data.createdBy == request.auth.uid;
      
      // Only the creator can modify or delete
      allow update, delete: if isSignedIn() 
        && resource.data.createdBy == request.auth.uid;
    }

    // Notifications
    match /notifications/{userId}/items/{notificationId} {
      allow read, write: if isOwner(userId);
    }

    // Ratings
    match /ratings/{ratingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.fromUser == request.auth.uid;
      allow update, delete: if false;
    }

    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}