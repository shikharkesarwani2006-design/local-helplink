rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LOCAL HELPLINK SECURITY RULES
     * Optimized for stability and real-time community feed access.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // User Profiles
    match /users/{userId} {
      // Allow any signed-in user to see profiles (needed for request details)
      allow read: if isSignedIn();
      // Only the user themselves can edit their profile
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    // Help Requests
    match /requests/{requestId} {
      // Critical: Allow all signed-in users to list and read requests
      allow read: if isSignedIn();
      
      // Allow creation if the user is signed in
      allow create: if isSignedIn();
      
      // Only the creator can modify or delete their own request
      allow update, delete: if isSignedIn() 
        && resource.data.createdBy == request.auth.uid;
    }

    // Notifications
    match /notifications/{userId}/items/{notificationId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Ratings
    match /ratings/{ratingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Ratings are typically permanent
      allow update, delete: if false;
    }

    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}