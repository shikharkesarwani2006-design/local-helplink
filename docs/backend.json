
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents a user account within the Local HelpLink platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "bio": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "area": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "role": { "type": "string", "enum": ["user", "volunteer", "provider", "admin"] },
        "skills": { "type": "array", "items": { "type": "string" } },
        "interests": { "type": "array", "items": { "type": "string" } },
        "serviceCategory": { "type": "string" },
        "experience": { "type": "string" },
        "serviceArea": { "type": "string" },
        "availability": { "type": "array", "items": { "type": "string" } },
        "workingHours": {
          "type": "object",
          "properties": {
            "from": { "type": "string" },
            "to": { "type": "string" }
          }
        },
        "hourlyRate": { "type": "number" },
        "availabilityHours": { "type": "string" },
        "rating": { "type": "number" },
        "totalRatingsCount": { "type": "number" },
        "totalHelped": { "type": "number" },
        "totalJobsDone": { "type": "number" },
        "verified": { "type": "boolean" },
        "isAvailable": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role", "verified", "createdAt"]
    },
    "HelpRequest": {
      "title": "HelpRequest",
      "description": "Represents a request for help posted by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["blood", "tutor", "repair", "emergency", "other"] },
        "location": {
          "type": "object",
          "properties": {
            "area": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "urgency": { "type": "string", "enum": ["high", "medium", "low"] },
        "status": { "type": "string", "enum": ["open", "accepted", "completed"] },
        "createdBy": { "type": "string" },
        "postedByName": { "type": "string" },
        "acceptedBy": { "type": "string" },
        "acceptedAt": { "type": "string", "format": "date-time" },
        "reported": { "type": "boolean", "default": false },
        "responseTime": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "contactPreference": { "type": "string" }
      },
      "required": ["id", "title", "description", "category", "location", "urgency", "status", "createdBy", "createdAt", "expiresAt"]
    },
    "Rating": {
      "title": "Rating",
      "description": "A review and rating left for a community member.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "requestId": { "type": "string" },
        "fromUser": { "type": "string" },
        "toUser": { "type": "string" },
        "score": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["requestId", "fromUser", "toUser", "score", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Stores individual user profiles."
    },
    "/requests/{requestId}": {
      "schema": { "$ref": "#/backend/entities/HelpRequest" },
      "description": "Stores individual help requests."
    },
    "/ratings/{ratingId}": {
      "schema": { "$ref": "#/backend/entities/Rating" },
      "description": "Global ratings collection."
    },
    "/notifications/{userId}/items/{notificationId}": {
      "schema": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "message": { "type": "string" },
          "type": { "type": "string" },
          "urgency": { "type": "string" },
          "requestId": { "type": "string" },
          "read": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "User specific notifications."
    }
  }
}
