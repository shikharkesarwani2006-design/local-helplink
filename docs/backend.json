
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user account within the Local HelpLink platform.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "area": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "role": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "interests": { "type": "array", "items": { "type": "string" }, "description": "Categories the user is interested in helping with." },
        "rating": { "type": "number" },
        "totalHelped": { "type": "number" },
        "verified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role", "verified", "createdAt"]
    },
    "HelpRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "HelpRequest",
      "type": "object",
      "description": "Represents a request for help posted by a user.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["blood", "tutor", "repair", "emergency", "other"] },
        "location": {
          "type": "object",
          "properties": {
            "area": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "urgency": { "type": "string", "enum": ["high", "medium", "low"] },
        "status": { "type": "string" },
        "createdBy": { "type": "string" },
        "postedByName": { "type": "string" },
        "acceptedBy": { "type": "string" },
        "responseTime": { "type": "number", "description": "Response time in minutes." },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "description", "category", "location", "urgency", "status", "createdBy", "createdAt", "expiresAt"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "description": "Stores individual user profiles."
        }
      },
      {
        "path": "/requests/{requestId}",
        "definition": {
          "entityName": "HelpRequest",
          "description": "Stores individual help requests."
        }
      },
      {
        "path": "/notifications/{userId}/items/{notificationId}",
        "definition": {
          "schema": {
             "type": "object",
             "properties": {
               "title": { "type": "string" },
               "message": { "type": "string" },
               "type": { "type": "string" },
               "read": { "type": "boolean" },
               "createdAt": { "type": "string", "format": "date-time" }
             }
          },
          "description": "User specific notifications."
        }
      }
    ]
  }
}
